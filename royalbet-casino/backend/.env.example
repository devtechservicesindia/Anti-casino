# ─────────────────────────────────────────────────────────
#  RoyalBet Casino – Backend Environment Variables
#  Copy this file to .env and fill in all values before
#  starting the server. NEVER commit .env to source control.
# ─────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────
DATABASE_URL=

# ── Cache (Redis 7) ───────────────────────────────────────
REDIS_URL=

# ── Authentication ────────────────────────────────────────
JWT_SECRET=
JWT_REFRESH_SECRET=

# ── Payments (Razorpay) ───────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── SMS / OTP (Twilio) ────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ── OAuth (Google) ────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── Google Cloud Storage ──────────────────────────────────
GCS_BUCKET_NAME=

# ── App Config ────────────────────────────────────────────
FRONTEND_URL=
NODE_ENV=development
PORT=4000
