// ─────────────────────────────────────────────────────────────────────────────
//  RoyalBet Casino – Prisma Schema
//  Database : SQLite (local dev) — swap provider + restore enums for production
//  ORM      : Prisma 5
// ─────────────────────────────────────────────────────────────────────────────

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ═════════════════════════════════════════════════════════════════════════════
//  MODELS
//  NOTE: SQLite does not support native enums or Json.
//        Enum fields are stored as String; Json is stored as String.
//        Values should still match the enum constants used in app code.
// ═════════════════════════════════════════════════════════════════════════════

// ── 1. User ──────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String?
  googleId     String?  @unique
  avatarUrl    String?
  isBanned     Boolean  @default(false)
  role         String   @default("USER")   // UserRole: USER | ADMIN
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  wallet              Wallet?
  transactions        Transaction[]
  gameSessions        GameSession[]
  bonuses             Bonus[]
  referralsGiven      Referral[]         @relation("ReferrerRelation")
  referralReceived    Referral?          @relation("ReferredRelation")
  leaderboardEntries  LeaderboardEntry[]
  tournamentEntries   TournamentEntry[]
  userAchievements    UserAchievement[]
  adminLogs           AdminLog[]         @relation("AdminLogsAdmin")
  refreshTokens       RefreshToken[]

  @@map("users")
}

// ── 2. Wallet ─────────────────────────────────────────────────────────────────
model Wallet {
  id             String   @id @default(cuid())
  userId         String   @unique
  balance        Decimal  @default(500)
  totalPurchased Decimal  @default(0)
  totalSpent     Decimal  @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("wallets")
}

// ── 3. TokenPackage ──────────────────────────────────────────────────────────
model TokenPackage {
  id           String   @id @default(cuid())
  name         String
  tokenAmount  Int
  priceInr     Decimal
  bonusTokens  Int      @default(0)
  isActive     Boolean  @default(true)
  displayOrder Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("token_packages")
}

// ── 4. Transaction ────────────────────────────────────────────────────────────
model Transaction {
  id                String   @id @default(cuid())
  userId            String
  type              String   // TransactionType: PURCHASE | SPEND | BONUS | REFUND
  amount            Decimal
  razorpayOrderId   String?
  razorpayPaymentId String?
  status            String   @default("PENDING")  // TransactionStatus: PENDING | SUCCESS | FAILED
  note              String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("transactions")
}

// ── 5. GameSession ────────────────────────────────────────────────────────────
model GameSession {
  id         String   @id @default(cuid())
  userId     String
  gameType   String   // GameType: SLOTS | POKER | ROULETTE | BLACKJACK | CRASH
  betAmount  Decimal
  winAmount  Decimal  @default(0)
  result     String   // GameResult: WIN | LOSE | PUSH
  serverSeed String?
  clientSeed String?
  nonce      Int      @default(0)
  metadata   String?  // JSON serialized — SQLite has no native Json type
  playedAt   DateTime @default(now())
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([gameType])
  @@map("game_sessions")
}

// ── 6. Bonus ──────────────────────────────────────────────────────────────────
model Bonus {
  id          String   @id @default(cuid())
  userId      String
  type        String   // BonusType: DAILY | WELCOME | REFERRAL | HOURLY | STREAK
  tokensGiven Decimal
  streakDay   Int?
  claimedAt   DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("bonuses")
}

// ── 7. Referral ───────────────────────────────────────────────────────────────
model Referral {
  id         String   @id @default(cuid())
  referrerId String
  referredId String   @unique
  bonusGiven Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  referrer User @relation("ReferrerRelation", fields: [referrerId], references: [id], onDelete: Cascade)
  referred User @relation("ReferredRelation", fields: [referredId], references: [id], onDelete: Cascade)

  @@index([referrerId])
  @@index([referredId])
  @@map("referrals")
}

// ── 8. LeaderboardEntry ───────────────────────────────────────────────────────
model LeaderboardEntry {
  id            String   @id @default(cuid())
  userId        String
  gameType      String
  period        String   // LeaderboardPeriod: DAILY | WEEKLY | ALLTIME
  totalWinnings Decimal  @default(0)
  rank          Int
  updatedAt     DateTime @updatedAt
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, gameType, period])
  @@index([userId])
  @@map("leaderboard_entries")
}

// ── 9. Tournament ─────────────────────────────────────────────────────────────
model Tournament {
  id         String   @id @default(cuid())
  name       String
  gameType   String
  entryFee   Decimal
  prizePool  Decimal
  maxPlayers Int
  startTime  DateTime
  endTime    DateTime
  status     String   @default("UPCOMING")  // TournamentStatus: UPCOMING | LIVE | COMPLETED
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  entries TournamentEntry[]

  @@map("tournaments")
}

// ── 10. TournamentEntry ────────────────────────────────────────────────────────
model TournamentEntry {
  id           String   @id @default(cuid())
  tournamentId String
  userId       String
  score        Decimal  @default(0)
  rank         Int?
  prizeWon     Decimal  @default(0)
  joinedAt     DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tournament Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tournamentId, userId])
  @@index([tournamentId])
  @@index([userId])
  @@map("tournament_entries")
}

// ── 11. Achievement ────────────────────────────────────────────────────────────
model Achievement {
  id             String   @id @default(cuid())
  name           String   @unique
  description    String
  icon           String
  conditionType  String
  conditionValue Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  userAchievements UserAchievement[]

  @@map("achievements")
}

// ── 12. UserAchievement ────────────────────────────────────────────────────────
model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  earnedAt      DateTime @default(now())
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
  @@map("user_achievements")
}

// ── 13. AdminLog ──────────────────────────────────────────────────────────────
model AdminLog {
  id           String   @id @default(cuid())
  adminId      String
  action       String
  targetUserId String?
  note         String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  admin User @relation("AdminLogsAdmin", fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@map("admin_logs")
}

// ── 14. RefreshToken ──────────────────────────────────────────────────────────
model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @unique
  token     String   // bcrypt hash of the actual refresh token
  expiresAt DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}
